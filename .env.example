# ─────────────────────────────────────────────────────────────────────────────
#  Origin Hub Registry — Environment Configuration
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, good for single-server deployments)
DATABASE_URL=sqlite+aiosqlite:////data/origin_hub.db

# ── Storage ───────────────────────────────────────────────────────────────────
# Directory where .originpkg bundles are stored
STORAGE_PATH=/storage

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: Replace with a long random string before deploying to production.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_STRING_IN_PRODUCTION

# ── Server ────────────────────────────────────────────────────────────────────
# Port the server listens on inside the container
PORT=8000

# Number of uvicorn worker processes (increase for multi-core prod servers)
# Rule of thumb: 2 * CPU_CORES + 1 (keep at 1 for SQLite to avoid write conflicts)
WORKERS=1

# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info

# ── Limits ────────────────────────────────────────────────────────────────────
# Maximum size of an uploaded .originpkg bundle (in MB)
MAX_BUNDLE_SIZE_MB=50

# Default page size for paginated list endpoints
DEFAULT_PAGE_SIZE=20

# ── Docker Compose (optional overrides) ───────────────────────────────────────
# Host port to expose (maps to PORT inside container)
HOST_PORT=8000

# Image name and tag used by docker-compose.yml
IMAGE_NAME=origin-hub-registry
IMAGE_TAG=latest
